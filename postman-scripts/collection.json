  "item": [
    {
      "name": "Creates a duplicate repository for the authenticated user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//Set the repository name as a global variable \r",
              "pm.globals.set(\"repoName\", \"TestRepo\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "//validate the response status code of the duplicate repository request",
              "pm.test(\"validate the response status code of the duplicate repository request\", function () { ",
              "    pm.expect(pm.response.code).to.eql(422); ",
              "});",
              "",
              "//validate the status message of the duplicate repository request",
              "pm.test(\"validate the response status message of the duplicate repository request\", function () { ",
              "    pm.expect(pm.response.status).to.include(\"Unprocessable Entity\"); ",
              "});",
              "",
              "//validate the response time of the duplicate repository request",
              "pm.test(\"validate the response time of the duplicate repository request\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "//validate the response body of the duplicate repository request",
              "pm.test(\"validate the response body of the duplicate repository request\", function () {",
              "    pm.expect(pm.response.json().message).to.eql(\"Repository creation failed.\");",
              "    pm.expect(pm.response.json().errors[0].message).to.eql(\"name already exists on this account\");",
              "    pm.expect(pm.response.json().status).to.eql(\"422\");",
              "});",
              "",
              "//create a method to wait for 2 sec",
              "setTimeout(()=>{",
              "    console.log(\"Waiting for 2 seconds!\");",
              "},2000);",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{bearer_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/vnd.github+json",
            "type": "text"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2026-03-10",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":\"{{repoName}}\",\r\n    \"private\": true,\r\n    \"description\": \"Sample duplicate repo from Postman\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/user/repos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        }
      },
      "response": []
